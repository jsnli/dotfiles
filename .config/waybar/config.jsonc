{
	"layer": "top",
	"modules-left": ["hyprland/workspaces", "hyprland/mode"],
	"modules-center": ["hyprland/window"],
	"modules-right": ["pulseaudio", "pulseaudio/slider", "clock"],
	"hyprland/window": {
		"max-length": 50
	},
	"clock": {
		"format": "{:%H:%M} "
	},
	"pulseaudio": {
		"format": "{volume}% {icon}",
		"format-bluetooth": "{volume}% {icon}´èö",
		"format-muted": "´ÇĞ",
		"format-icons": {
